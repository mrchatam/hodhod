# Hodhod — seller custom domain (Nginx example)
# Replace __SELLER_DOMAIN__ and __HTTP_PORT__ before use.
# Webhooks stay on the main PUBLIC_BASE_URL domain.

upstream hodhod_app {
    server 127.0.0.1:__HTTP_PORT__;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name __SELLER_DOMAIN__;

    client_max_body_size 20m;

    location / {
        proxy_pass http://hodhod_app;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# TLS: certbot --nginx -d __SELLER_DOMAIN__ --redirect
