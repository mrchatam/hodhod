# Hodhod - Multi-tenant VPN sales bot
ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://your-domain.example

# PostgreSQL (compose default uses hodhod/hodhod)
DATABASE_DSN=postgres://hodhod:hodhod@hodhod-db:5432/hodhod?sslmode=disable
RUN_MIGRATIONS=true

# 32-byte key, base64-encoded (generate: openssl rand -base64 32)
APP_ENCRYPTION_KEY=

# Optional SOCKS5 for Telegram + panels (empty = direct). Example: socks5h://host.docker.internal:10810
OUTBOUND_SOCKS_PROXY=

# 1 = app container uses host network (fix when host curl reaches Telegram but Docker bridge egress fails)
HODHOD_HOST_NETWORK=0
# localhost port for Postgres when HODHOD_HOST_NETWORK=1 (15432 avoids conflict with system postgres on 5432)
HODHOD_DB_HOST_PORT=15432
# 1 = Postgres already published on 127.0.0.1:HODHOD_DB_HOST_PORT — do not recreate db
HODHOD_DB_ALREADY_LOCAL=0

SESSION_SECRET=change-me-to-random-64-chars
LOG_LEVEL=info

# Master admin — prefer one-time bootstrap (deprecated env seed):
#   hodhod bootstrap-admin --username admin --password 'your-secure-password'
MASTER_USERNAME=admin
# MASTER_PASSWORD=  # optional one-release legacy; omit for production

PANEL_POLL_WORKERS=4
CRON_USAGE_POLL=@every 5m
CRON_EXPIRY_CHECK=@every 1h
CRON_BACKUP=0 3 * * *
BACKUP_DIR=./data/backups

# Allow seller custom domains (Host header routing)
ALLOW_CUSTOM_DOMAINS=true
