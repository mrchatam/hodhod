# Hodhod - Multi-tenant VPN sales bot
ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://your-domain.example

# PostgreSQL (compose default uses hodhod/hodhod)
DATABASE_DSN=postgres://hodhod:hodhod@hodhod-db:5432/hodhod?sslmode=disable
RUN_MIGRATIONS=true

# 32-byte key, base64-encoded (generate: openssl rand -base64 32)
APP_ENCRYPTION_KEY=

# Optional SOCKS5 for Telegram + panels (empty = direct). Example: socks5h://host.docker.internal:10810
OUTBOUND_SOCKS_PROXY=

SESSION_SECRET=change-me-to-random-64-chars
LOG_LEVEL=info

# Master admin (created on first boot if none exists)
MASTER_USERNAME=admin
MASTER_PASSWORD=changeme

PANEL_POLL_WORKERS=4
CRON_USAGE_POLL=@every 5m
CRON_EXPIRY_CHECK=@every 1h
CRON_BACKUP=0 3 * * *
BACKUP_DIR=./data/backups

# Allow seller custom domains (Host header routing)
ALLOW_CUSTOM_DOMAINS=true
